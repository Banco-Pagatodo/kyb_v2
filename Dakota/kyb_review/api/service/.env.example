# ============================================================================
# KYB API - Variables de Entorno
# ============================================================================
# INSTRUCCIONES:
# 1. Copiar este archivo como .env
# 2. Reemplazar los valores con las credenciales reales
# 3. NUNCA commitear el archivo .env con credenciales reales
# ============================================================================

# ----------------------------------------------------------------------------
# Azure Document Intelligence (OCR)
# Obtener de: Azure Portal > Document Intelligence > Keys and Endpoint
# ----------------------------------------------------------------------------
DI_ENDPOINT=https://<region>.api.cognitive.microsoft.com/
DI_KEY=<tu-api-key-aqui>

# ----------------------------------------------------------------------------
# Azure OpenAI
# Obtener de: Azure Portal > Azure OpenAI > Keys and Endpoint
# ----------------------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://<nombre-recurso>.openai.azure.com/
AZURE_DEPLOYMENT_NAME=gpt-4o
AZURE_EMBEDDING_DEPLOYMENT=text-embedding-ada-002
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_API_KEY=<tu-api-key-aqui>

# ----------------------------------------------------------------------------
# Azure Storage (Opcional - para almacenamiento de documentos)
# ----------------------------------------------------------------------------
STORAGE_ACCOUNT=<nombre-cuenta-storage>
STORAGE_KEY=<tu-storage-key-aqui>

# ----------------------------------------------------------------------------
# Configuracion de la API (Produccion)
# ----------------------------------------------------------------------------
# Ambiente: development | staging | production
ENVIRONMENT=production

# API Key para autenticacion (generar con: python -c "import secrets; print(secrets.token_urlsafe(32))")
API_KEY=<generar-api-key-segura>

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# ----------------------------------------------------------------------------
# Configuracion de Limpieza Automatica
# ----------------------------------------------------------------------------
CLEANUP_ON_STARTUP=true
CLEANUP_MAX_AGE_DAYS=7

# ----------------------------------------------------------------------------
# PostgreSQL (Persistencia de datos extraídos)
# Opción A: URL completa
# DATABASE_URL=postgresql+asyncpg://kyb_app:password@localhost:5432/kyb
#
# Opción B: Variables individuales
# ----------------------------------------------------------------------------
DB_USER=kyb_app
DB_PASS=<tu-password-aqui>
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kyb
DB_SSL=prefer
# DB_ECHO=false       # true para ver queries SQL en logs (solo desarrollo)
# DB_POOL_SIZE=5      # conexiones en pool
# DB_MAX_OVERFLOW=10  # conexiones extra permitidas

# ----------------------------------------------------------------------------
# Azure Computer Vision (CAPTCHA OCR para portales gubernamentales)
# Obtener de: Azure Portal > Computer Vision > Keys and Endpoint
# ----------------------------------------------------------------------------
AZURE_CV_ENDPOINT=https://<nombre-recurso>.cognitiveservices.azure.com
AZURE_CV_KEY=<tu-api-key-aqui>

# Estrategia CAPTCHA: manual | ocr | azure_ocr | gpt4_vision | cascada
PORTAL_CAPTCHA_STRATEGY=azure_ocr

