# ── Orquestrator — Pipeline KYB (Flujo Dakota) ──────────────────
# Copia este archivo como .env y ajusta los valores para tu entorno.

# URLs de los agentes downstream
DAKOTA_BASE_URL=http://localhost:8010
COLORADO_BASE_URL=http://localhost:8011
ARIZONA_BASE_URL=http://localhost:8012
NEVADA_BASE_URL=http://localhost:8013

# Puerto del Orquestrator
ORQUESTRATOR_PORT=8002

# Autenticación Dakota (opcional)
DAKOTA_API_KEY=

# Timeouts HTTP (segundos)
DAKOTA_TIMEOUT=300
COLORADO_TIMEOUT=300
ARIZONA_TIMEOUT=120
NEVADA_TIMEOUT=120

# ── Base de datos PostgreSQL (compartida kyb) ────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kyb
DB_USER=kyb_app
DB_PASS=kyb_app
